generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InsuranceCategory {
  IARDT
  PERSONNES
  VIE
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
  ONE_TIME
}

enum OfferStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LeadStatus {
  DRAFT
  NEW
  CONTACTED
  PROCESSING
  INSURER_PENDING
  COMPLETED
  CONVERTED
  LOST
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ClaimStatus {
  PENDING
  PROCESSING
  RESOLVED
  REJECTED
}

enum AdminRole {
  ADMIN
  EDITOR
}

model Insurer {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  logoUrl           String?
  description       String?
  website           String?
  phone             String?
  address           String?
  generalConditions String?             @db.Text
  categories        InsuranceCategory[] @default([])
  offers            Offer[]
  tariffRules       TariffRule[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model InsuranceType {
  id          String            @id @default(cuid())
  label       String
  slug        String            @unique
  category    InsuranceCategory
  subType     String?
  description String?
  offers      Offer[]
  tariffRules TariffRule[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([category])
}

model Offer {
  id                 String            @id @default(cuid())
  category           InsuranceCategory
  insuranceTypeId    String?
  insuranceType      InsuranceType?    @relation(fields: [insuranceTypeId], references: [id], onDelete: SetNull)
  insuranceTypeLabel String
  insuranceSubType   String?
  insurerId          String
  insurer            Insurer           @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  premium            Decimal           @db.Decimal(12, 2)
  billingPeriod      BillingPeriod     @default(ANNUAL)
  rate               Decimal?          @db.Decimal(6, 3)
  coverageAmount     Decimal           @db.Decimal(14, 2)
  franchise          Decimal           @default(0) @db.Decimal(12, 2)
  guarantees         String[]          @default([])
  optionalGuarantees String[]          @default([])
  exclusions         String[]          @default([])
  duration           String            @default("12 mois")
  waitingPeriod      String            @default("Immediat")
  terms              String?
  rating             Decimal           @default(0) @db.Decimal(2, 1)
  isMandatory        Boolean           @default(false)
  tag                String?
  status             OfferStatus       @default(ACTIVE)
  metadata           Json?
  guaranteeLinks     OfferGuarantee[]
  tariffRules        TariffRule[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([category, insuranceTypeLabel])
  @@index([insurerId])
  @@index([status])
}

model Guarantee {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String?
  category        InsuranceCategory?
  offerGuarantees OfferGuarantee[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model OfferGuarantee {
  id          String    @id @default(cuid())
  offerId     String
  offer       Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  guaranteeId String
  guarantee   Guarantee @relation(fields: [guaranteeId], references: [id], onDelete: Cascade)
  included    Boolean   @default(true)
  details     String?

  @@unique([offerId, guaranteeId])
}

model TariffRule {
  id                 String            @id @default(cuid())
  offerId            String?
  offer              Offer?            @relation(fields: [offerId], references: [id], onDelete: SetNull)
  insurerId          String
  insurer            Insurer           @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  insuranceTypeId    String?
  insuranceType      InsuranceType?    @relation(fields: [insuranceTypeId], references: [id], onDelete: SetNull)
  category           InsuranceCategory
  insuranceTypeLabel String
  zone               String            @default("Zone Rouge")
  vehicleUsage       String?
  vehiclePower       String?
  vehicleEnergy      String?
  duration           String?
  price              Decimal           @db.Decimal(12, 2)
  currency           String            @default("XOF")
  guarantees         String[]          @default([])
  active             Boolean           @default(true)
  validFrom          DateTime?
  validUntil         DateTime?
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([category, insuranceTypeLabel])
  @@index([vehicleUsage, vehiclePower, vehicleEnergy, duration])
  @@index([active])
}

model QuoteRequest {
  id              String             @id @default(cuid())
  clientId        String?
  client          Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  fullName        String
  email           String?
  phone           String
  company         String?
  category        InsuranceCategory?
  insuranceType   String?
  budget          Decimal?           @db.Decimal(12, 2)
  selectedOfferId String?
  message         String?
  payload         Json?
  status          LeadStatus         @default(NEW)
  policyNumber    String?
  receiptUrl      String?
  contractUrl     String?
  signatureUrl    String?
  // ── Multi-Broker fields ──
  brokerId        String?
  broker          Broker?            @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  brokerCode      String?            // Code courtier saisi par le client
  platformFee     Decimal?           @db.Decimal(12, 2) // Montant retenu par LBASSUR
  brokerShare     Decimal?           @db.Decimal(12, 2) // Part reversée au courtier externe
  // ── Relations ──
  documents       Document[]
  payment         Payment?
  claims          Claim[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@index([brokerId])
}

model Document {
  id             String       @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  type           String // "carte_grise", "piece_identite", etc.
  filename       String
  url            String // path to the local or cloud file
  mimeType       String
  size           Int
  createdAt      DateTime     @default(now())

  @@index([quoteRequestId])
}

model Payment {
  id             String        @id @default(cuid())
  quoteRequestId String        @unique
  quoteRequest   QuoteRequest  @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  method         String // "MTN", "MOOV", "VISA", "MASTERCARD"
  status         PaymentStatus @default(PENDING)
  reference      String        @unique // e.g. "LB-XYZ123"
  commission     Commission?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ── Multi-Broker Models ──────────────────────────────────────────────────────

model Broker {
  id              String         @id @default(cuid())
  name            String                                    // "Cabinet XYZ"
  code            String         @unique                    // Code courtier officiel (ex: "CIMA-BJ-0042")
  slug            String         @unique
  contactEmail    String?
  contactPhone    String?
  commissionRate  Decimal        @default(70) @db.Decimal(5, 2)  // % de la commission qui revient au courtier (défaut 70%)
  platformRate    Decimal        @default(30) @db.Decimal(5, 2)  // % retenu par LBASSUR (défaut 30%)
  active          Boolean        @default(true)
  quotes          QuoteRequest[]
  commissions     Commission[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum CommissionStatus {
  PENDING
  PAID
  DISPUTED
}

model Commission {
  id              String           @id @default(cuid())
  paymentId       String           @unique
  payment         Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  totalPremium    Decimal          @db.Decimal(12, 2)
  platformRate    Decimal          @db.Decimal(5, 2)    // ex: 30
  platformAmount  Decimal          @db.Decimal(12, 2)   // Montant LBASSUR
  brokerRate      Decimal          @db.Decimal(5, 2)    // ex: 70
  brokerAmount    Decimal          @db.Decimal(12, 2)   // Montant courtier externe
  brokerId        String?
  broker          Broker?          @relation(fields: [brokerId], references: [id], onDelete: SetNull)
  status          CommissionStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([brokerId])
  @@index([status])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String?
  role         AdminRole @default(EDITOR)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Client {
  id           String                 @id @default(cuid())
  phone        String                 @unique
  email        String?                @unique
  passwordHash String?
  fullName     String?
  quotes       QuoteRequest[]
  claims       Claim[]
  changeRequests ProfileChangeRequest[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Claim {
  id             String        @id @default(cuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  quoteRequestId String?
  quoteRequest   QuoteRequest? @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)
  description    String        @db.Text
  incidentDate   DateTime
  status         ClaimStatus   @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProfileChangeRequest {
  id               String        @id @default(cuid())
  clientId         String
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requestedData    Json          // Will store e.g., { phone: "...", email: "..." }
  proofDocumentUrl String
  status           RequestStatus @default(PENDING)
  adminNote        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
}
