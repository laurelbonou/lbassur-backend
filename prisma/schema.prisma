generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InsuranceCategory {
  IARDT
  PERSONNES
  VIE
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
  ONE_TIME
}

enum OfferStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  PROCESSING
  INSURER_PENDING
  COMPLETED
  CONVERTED
  LOST
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AdminRole {
  ADMIN
  EDITOR
}

model Insurer {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  logoUrl     String?
  description String?
  website     String?
  phone       String?
  address     String?
  generalConditions String? @db.Text
  categories  InsuranceCategory[] @default([])
  offers      Offer[]
  tariffRules TariffRule[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model InsuranceType {
  id          String            @id @default(cuid())
  label       String
  slug        String            @unique
  category    InsuranceCategory
  subType     String?
  description String?
  offers      Offer[]
  tariffRules TariffRule[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([category])
}

model Offer {
  id                 String             @id @default(cuid())
  category           InsuranceCategory
  insuranceTypeId    String?
  insuranceType      InsuranceType?     @relation(fields: [insuranceTypeId], references: [id], onDelete: SetNull)
  insuranceTypeLabel String
  insuranceSubType   String?
  insurerId          String
  insurer            Insurer            @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  premium            Decimal            @db.Decimal(12, 2)
  billingPeriod      BillingPeriod      @default(ANNUAL)
  rate               Decimal?           @db.Decimal(6, 3)
  coverageAmount     Decimal            @db.Decimal(14, 2)
  franchise          Decimal            @default(0) @db.Decimal(12, 2)
  guarantees         String[]           @default([])
  optionalGuarantees String[]           @default([])
  exclusions         String[]           @default([])
  duration           String             @default("12 mois")
  waitingPeriod      String             @default("Immediat")
  terms              String?
  rating             Decimal            @default(0) @db.Decimal(2, 1)
  isMandatory        Boolean            @default(false)
  tag                String?
  status             OfferStatus        @default(ACTIVE)
  metadata           Json?
  guaranteeLinks     OfferGuarantee[]
  tariffRules        TariffRule[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([category, insuranceTypeLabel])
  @@index([insurerId])
  @@index([status])
}

model Guarantee {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String?
  category       InsuranceCategory?
  offerGuarantees OfferGuarantee[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model OfferGuarantee {
  id          String    @id @default(cuid())
  offerId     String
  offer       Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  guaranteeId String
  guarantee   Guarantee @relation(fields: [guaranteeId], references: [id], onDelete: Cascade)
  included    Boolean   @default(true)
  details     String?

  @@unique([offerId, guaranteeId])
}

model TariffRule {
  id                 String            @id @default(cuid())
  offerId            String?
  offer              Offer?            @relation(fields: [offerId], references: [id], onDelete: SetNull)
  insurerId          String
  insurer            Insurer           @relation(fields: [insurerId], references: [id], onDelete: Cascade)
  insuranceTypeId    String?
  insuranceType      InsuranceType?    @relation(fields: [insuranceTypeId], references: [id], onDelete: SetNull)
  category           InsuranceCategory
  insuranceTypeLabel String
  zone               String            @default("Zone Rouge")
  vehicleUsage       String?
  vehiclePower       String?
  vehicleEnergy      String?
  duration           String?
  price              Decimal           @db.Decimal(12, 2)
  currency           String            @default("XOF")
  guarantees         String[]          @default([])
  active             Boolean           @default(true)
  validFrom          DateTime?
  validUntil         DateTime?
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([category, insuranceTypeLabel])
  @@index([vehicleUsage, vehiclePower, vehicleEnergy, duration])
  @@index([active])
}

model QuoteRequest {
  id              String             @id @default(cuid())
  fullName        String
  email           String?
  phone           String
  company         String?
  category        InsuranceCategory?
  insuranceType   String?
  budget          Decimal?           @db.Decimal(12, 2)
  selectedOfferId String?
  message         String?
  payload         Json?
  status          LeadStatus         @default(NEW)
  policyNumber    String?
  receiptUrl      String?
  contractUrl     String?
  signatureUrl    String?
  documents       Document[]
  payment         Payment?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Document {
  id             String        @id @default(cuid())
  quoteRequestId String
  quoteRequest   QuoteRequest  @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  type           String        // "carte_grise", "piece_identite", etc.
  filename       String
  url            String        // path to the local or cloud file
  mimeType       String
  size           Int
  createdAt      DateTime      @default(now())

  @@index([quoteRequestId])
}

model Payment {
  id             String        @id @default(cuid())
  quoteRequestId String        @unique
  quoteRequest   QuoteRequest  @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  amount         Decimal       @db.Decimal(12, 2)
  method         String        // "MTN", "MOOV", "VISA", "MASTERCARD"
  status         PaymentStatus @default(PENDING)
  reference      String        @unique // e.g. "LB-XYZ123"
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String?
  role         AdminRole @default(EDITOR)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
