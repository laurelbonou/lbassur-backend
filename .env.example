PORT=4000
FRONTEND_URL=http://localhost:3000

# Admin API key for protected write endpoints (generate a strong random string)
ADMIN_API_KEY=<your-strong-random-api-key>

# Runtime connection: use the Neon pooler host.
DATABASE_URL="postgresql://<user>:<password>@<neon-pooler-host>/<database>?sslmode=require"

# Migration connection: use the direct Neon host.
DIRECT_URL="postgresql://<user>:<password>@<neon-direct-host>/<database>?sslmode=require"
